###########################################################################
#     Parameter file for Cado-NFS ; class group version
###########################################################################
# See params/params.c90 for an example which contains some documentation.

# This parameter file is only here to allow tests on small input. It may
# not be optimal but it is fast enough so the tests do not run for too
# long

###########################################################################
# General parameters
###########################################################################

name = d20

###########################################################################
# Sieve
###########################################################################

tasks.I = 13
tasks.lim0 = 800
tasks.lpb0 = 10
tasks.sieve.mfb0 = 20

tasks.sieve.qfac_nfac = 5
tasks.sieve.qfac_min = 100
tasks.sieve.qfac_max = 250
tasks.sieve.qrange = 25

tasks.sieve.ncurves0 = 2

tasks.sieve.rels_wanted = 250

###########################################################################
# Filtering
###########################################################################

# needed for small input, otherwise coeffs of the matrix will overflow
tasks.filter.target_density = 18
tasks.nmatrices = 2
